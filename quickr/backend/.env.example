# Backend Environment Configuration
# Copy this to backend/.env and fill in your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
# MongoDB Connection String
# Local: mongodb://localhost:27017/quick-reservation
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGO_URI=mongodb://localhost:27017/quick-reservation

# ============================================
# APPLICATION URLS
# ============================================
# URL for mobile app (for QR redirects)
MOBILE_APP_URL=http://localhost:5173

# URL for admin web panel
ADMIN_WEB_URL=http://localhost:3000

# ============================================
# SERVER CONFIGURATION
# ============================================
# Server port
PORT=5000

# Node environment
NODE_ENV=development

# ============================================
# AUTHENTICATION
# ============================================
# JWT Secret for admin authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT Expiration time
JWT_EXPIRES_IN=24h

# ============================================
# PAYMENT GATEWAY (Optional)
# ============================================
# Razorpay credentials
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ============================================
# LOGGING & DEBUG
# ============================================
# Enable debug logging
DEBUG=true

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================
# CORS CONFIGURATION
# ============================================
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001

# ============================================
# SESSION CONFIGURATION
# ============================================
# Session timeout in milliseconds (24 hours)
SESSION_TIMEOUT=86400000

# ============================================
# HOTEL CONFIGURATION
# ============================================
# Default hotel name
DEFAULT_HOTEL=abhirami

# Number of tables
NUMBER_OF_TABLES=10

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
# SMTP configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@abhiramihotel.com

# ============================================
# TWILIO CONFIGURATION (Optional - for SMS)
# ============================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+91xxxxxxxxxx

# ============================================
# SENTRY CONFIGURATION (Optional - Error tracking)
# ============================================
SENTRY_DSN=

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/disable specific features
ENABLE_PAYMENTS=true
ENABLE_NOTIFICATIONS=false
ENABLE_ANALYTICS=true

